{
  "name": "simple-youtube",
  "description": "Simple YouTube is a lightweight extension that simplifies your YouTube experience by removing unnecessary clutter.",
  "private": true,
  "version": "2.3.2",
  "type": "module",
  "scripts": {
    "build": "wxt build && wxt build -b firefox",
    "dev": "wxt",
    "postinstall": "wxt prepare",
    "typecheck": "wxt prepare && tsc --noEmit",
    "zip": "wxt zip && wxt zip -b firefox"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.2.2",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "wxt": "^0.20.26"
  }
}
